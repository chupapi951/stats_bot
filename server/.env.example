# ===== Telegram =====
# Get from @BotFather
BOT_TOKEN=123456:REPLACE_WITH_YOUR_BOT_TOKEN

# Public HTTPS URL of the Mini App (no trailing slash)
# Locally you can use a tunnel (e.g. https://your-subdomain.ngrok-free.app)
WEBAPP_URL=https://your-domain.example.com

# ===== Server =====
PORT=3000

# Comma-separated Telegram user IDs allowed to use the bot
# Leave empty to allow everyone (not recommended in production)
ALLOWED_USERS=

# ===== Database =====
# Set to "memory" to use a built-in in-process MongoDB (great for dev / demo)
# Set to "mongo" and provide MONGO_URI to use a real MongoDB
DB_MODE=memory
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=stats_bot
